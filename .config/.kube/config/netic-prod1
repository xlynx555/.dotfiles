apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://prod1-api.jysk-prod.dedicated.k8s.jysk.netic.dk:6443
  name: jysk-prod-prod1
contexts:
- context:
    cluster: jysk-prod-prod1
    namespace: default
    user: keycloak
  name: jysk-prod-prod1
current-context: jysk-prod-prod1
kind: Config
preferences: {}
users:
- name: keycloak
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      args:
      - oidc-login
      - get-token
      - --oidc-use-pkce
      - --oidc-issuer-url=https://oidc.jysk.com/auth/realms/kubernetes
      - --oidc-client-id=prod1.jysk-prod.dedicated.k8s.jysk.netic.dk
      - --oidc-auth-request-extra-params=kc_idp_hint=saml
      command: kubectl
      env: null
      interactiveMode: IfAvailable
      provideClusterInfo: false
