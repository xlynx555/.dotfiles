apiVersion: v1
kind: Config
preferences: {}
clusters:
- name: jysk-dev-dev2
  cluster:
    certificate-authority-data: 
    server: https://dev2-api.jysk-dev.dedicated.k8s.jysk.netic.dk:6443
users:
- name: keycloak
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: kubectl
      args:
      - oidc-login
      - get-token
      - --oidc-issuer-url=https://oidc.jysk.com/auth/realms/kubernetes
      - --oidc-client-id=dev1.jysk-dev.dedicated.k8s.jysk.netic.dk
      - --oidc-auth-request-extra-params=kc_idp_hint=saml
contexts:
- context:
    cluster: jysk-dev-dev2
    user: keycloak
  name: jysk-dev-dev2
current-context: jysk-dev-dev2
