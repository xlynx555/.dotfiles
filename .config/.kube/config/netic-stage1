apiVersion: v1
kind: Config
preferences: {}
clusters:
- name: jysk-stage-stage1
  cluster:
    certificate-authority-data: 
    server: https://stage1-api.jysk-stage.dedicated.k8s.jysk.netic.dk:6443
users:
- name: keycloak
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: kubectl
      args:
      - oidc-login
      - get-token
      - --oidc-use-pkce
      - --oidc-issuer-url=https://oidc.jysk.com/auth/realms/kubernetes
      - --oidc-client-id=stage1.jysk-stage.dedicated.k8s.jysk.netic.dk
      - --oidc-auth-request-extra-params=kc_idp_hint=saml
contexts:
- context:
    cluster: jysk-stage-stage1
    user: keycloak
  name: jysk-stage-stage1
current-context: jysk-stage-stage1
